{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/node",
    "rootDir": "src/node",
    "types": ["node"],
    "declaration": true
  },
  "include": ["src/node/**/*.ts"]
}
